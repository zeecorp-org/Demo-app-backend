APP_NAME=Demo App Backend
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false
DOCS_ENABLED=true
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=["*"]
TRUSTED_HOSTS=["*"]
